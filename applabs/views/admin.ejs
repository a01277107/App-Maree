<!DOCTYPE html>
<html>
  <%- include('includes/head') %>
  <body>
    <h1><%= pageTitle %></h1>

    <h2>Agregar producto</h2>
    <form method="POST" action="/admin/add">
      Nombre: <input type="text" name="nombre" required><br>
      Precio: <input type="number" name="precio" required><br>
      Descripción: <input type="text" name="descripcion" required><br>
      Imagen (URL): <input type="text" name="imagen" required><br>
      Categoría:
     <select name="categoria" required>
      <option value="arma">Arma tu Crepa</option>
      <option value="especiales">Especiales</option>
      <option value="artesanales">Artesanales</option>
      <option value="saladas">Saladas</option>
     </select><br>
  <button type="submit">Agregar</button>
</form>

      <button type="submit">Agregar</button>
    </form>

    <h2>Productos actuales</h2>
    <% if (productos.length > 0) { %>
      <table>
        <thead><tr><th>Nombre</th><th>Precio</th><th>Acción</th></tr></thead>
        <tbody>
          <% productos.forEach(p => { %>
            <tr>
              <td><%= p.nombre %></td>
              <td>$<%= p.precio %></td>
              <td>
                <form method="POST" action="/admin/delete">
                  <input type="hidden" name="nombre" value="<%= p.nombre %>">
                  <button type="submit">Eliminar</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p>No hay productos registrados.</p>
    <% } %>

    <%- include('includes/footer') %>
  </body>
</html>

