<%- include('partials/page-start-admin', { title, path }) %>

<section class="space-y-6">
  <div class="glass p-6 flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Menú</h1>
      <p class="text-neutral-700 mt-2">Organización por categorías y subgrupos (prototipo). Aquí solo visualizamos; en una versión real habría CRUD.</p>
    </div>
    <a class="lovable-btn inline-flex items-center rounded-xl bg-white/70 px-4 py-2 text-sm border border-white/50 hover:bg-white" href="/admin">Volver</a>
  </div>

  <% categories.forEach(c => { %>
    <div class="glass p-5">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold"><%= c.name %></h2>
        <span class="text-sm text-neutral-600"><%= c.groups.length %> subgrupos</span>
      </div>

      <div class="mt-4 space-y-4">
        <% c.groups.forEach(g => { %>
          <div class="rounded-2xl border border-white/50 bg-white/55 p-4">
            <div class="flex items-center justify-between">
              <h3 class="font-semibold"><%= g.name %></h3>
              <span class="text-sm text-neutral-600"><%= g.items.length %> productos</span>
            </div>

            <div class="mt-3 grid md:grid-cols-2 gap-3">
              <% g.items.slice(0, 6).forEach(it => { %>
                <div class="rounded-xl border border-white/50 bg-white/60 p-3">
                  <div class="flex items-center justify-between gap-2">
                    <div class="font-medium"><%= it.name %></div>
                    <div class="text-sm text-neutral-700"><%= formatMoney(it.price) %></div>
                  </div>
                  <% if (it.description) { %>
                    <div class="text-sm text-neutral-600 mt-1 line-clamp-2"><%= it.description %></div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% }) %>
</section>


<%- include('partials/page-end-admin') %>
