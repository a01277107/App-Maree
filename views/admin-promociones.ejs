<%- include('partials/page-start-admin', { title, path }) %>

<section class="space-y-6">
  <div class="glass p-6 flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Promociones</h1>
      <p class="text-neutral-700 mt-2">Listado de promociones segmentadas (mock). Útil para mostrar el módulo del admin.</p>
    </div>
    <a class="lovable-btn inline-flex items-center rounded-xl bg-white/70 px-4 py-2 text-sm border border-white/50 hover:bg-white" href="/admin">Volver</a>
  </div>

  <div class="glass p-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h2 class="text-lg font-semibold">Activas</h2>
      <button class="lovable-btn rounded-xl bg-white/70 px-4 py-2 text-sm border border-white/50 hover:bg-white" type="button">Crear promoción (demo)</button>
    </div>

    <div class="mt-4 grid md:grid-cols-2 gap-4">
      <% promos.forEach(p => { %>
        <div class="rounded-2xl border border-white/50 bg-white/55 p-5">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="font-semibold text-lg"><%= p.name %></div>
              <div class="text-sm text-neutral-600 mt-1"><%= p.description %></div>
            </div>
            <span class="text-xs rounded-full border border-white/50 bg-white/70 px-3 py-1 text-neutral-700"><%= p.segment %></span>
          </div>
          <div class="mt-4 flex flex-wrap gap-2 text-sm text-neutral-700">
            <span class="rounded-full border border-white/50 bg-white/70 px-3 py-1">Código: <%= p.code %></span>
            <span class="rounded-full border border-white/50 bg-white/70 px-3 py-1">Vigencia: <%= p.range %></span>
          </div>
          <div class="mt-4 flex gap-2">
            <button class="lovable-btn rounded-xl bg-white/70 px-4 py-2 text-sm border border-white/50 hover:bg-white" type="button">Editar</button>
            <button class="lovable-btn rounded-xl bg-white/70 px-4 py-2 text-sm border border-white/50 hover:bg-white" type="button">Desactivar</button>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>


<%- include('partials/page-end-admin') %>
