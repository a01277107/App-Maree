<%- include('partials/page-start', { title, path }) %>

<div class="flex items-end justify-between gap-4 flex-wrap">
  <div>
    <h1 class="text-2xl md:text-3xl font-semibold tracking-tight">Mis crepas</h1>
    <p class="text-neutral-600 text-sm mt-1">Configuraciones guardadas desde “Arma tu crepa”.</p>
  </div>
  <a href="/armar-crepa" class="rounded-2xl bg-neutral-900 text-white px-4 py-2 text-sm hover:opacity-90 transition">Crear nueva</a>
</div>

<div class="mt-6">
  <% if (!saved || saved.length === 0) { %>
    <div class="rounded-3xl border border-neutral-200 bg-white p-6 glass">
      <p class="text-neutral-600">Aún no tienes crepas guardadas.</p>
      <a href="/armar-crepa" class="mt-4 inline-flex rounded-2xl border border-neutral-300 bg-white px-4 py-2 text-sm hover:bg-neutral-50 transition glass">Ir a Arma tu crepa</a>
    </div>
  <% } else { %>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% saved.slice().reverse().forEach((c) => { %>
        <div class="rounded-3xl border border-neutral-200 bg-white p-5 glass">
          <p class="text-sm text-neutral-500">Guardada</p>
          <h2 class="mt-1 font-semibold"><%= c.name %></h2>
          <p class="mt-2 text-sm text-neutral-600"><%= c.meta?.summaryLine || '' %></p>
          <p class="mt-3 text-lg font-semibold"><%= formatMoney(c.meta?.total || 0) %></p>

          <form method="POST" action="/mi-crepa/agregar-carrito" class="mt-4">
            <input type="hidden" name="savedId" value="<%= c.id %>" />
            <button class="w-full rounded-2xl bg-neutral-900 text-white px-4 py-2 text-sm hover:opacity-90 transition" type="submit">Agregar al carrito</button>
          </form>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/page-end') %>
