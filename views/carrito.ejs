<%- include('partials/page-start', { title, path }) %>

<div class="flex items-end justify-between gap-4 flex-wrap">
  <div>
    <h1 class="text-2xl md:text-3xl font-semibold tracking-tight">Carrito</h1>
    <p class="text-neutral-600 text-sm mt-1">Revisa productos y confirma tu pedido (demo).</p>
  </div>
  <div class="flex gap-2">
    <form method="POST" action="/carrito/limpiar">
      <button class="rounded-2xl border border-neutral-300 bg-white px-4 py-2 text-sm hover:bg-neutral-50 transition glass" type="submit">Vaciar</button>
    </form>
    <a href="/menu" class="rounded-2xl border border-neutral-300 bg-white px-4 py-2 text-sm hover:bg-neutral-50 transition glass">Seguir comprando</a>
  </div>
</div>

<div class="mt-6 grid lg:grid-cols-3 gap-6">
  <section class="lg:col-span-2 space-y-3">
    <% if (!cart || cart.length === 0) { %>
      <div class="rounded-3xl border border-neutral-200 bg-white p-6 glass">
        <p class="text-neutral-600">Tu carrito está vacío.</p>
        <a href="/menu" class="mt-4 inline-flex rounded-2xl bg-neutral-900 text-white px-4 py-2 text-sm hover:opacity-90 transition">Ir al menú</a>
      </div>
    <% } else { %>
      <% cart.forEach((item, idx) => { %>
        <div class="rounded-3xl border border-neutral-200 bg-white p-5 glass">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-semibold"><%= item.name %></p>
              <p class="text-sm text-neutral-600">Cantidad: <%= item.qty %> · Unit: <%= formatMoney(item.unitPrice) %></p>
              <% if (item.note) { %>
                <p class="text-xs text-neutral-500 mt-1">Nota: <%= item.note %></p>
              <% } %>
            </div>
            <div class="text-right">
              <p class="font-semibold"><%= formatMoney(item.total) %></p>
              <form method="POST" action="/carrito/eliminar" class="mt-2">
                <input type="hidden" name="index" value="<%= idx %>" />
                <button class="text-xs text-neutral-600 hover:text-neutral-900 underline underline-offset-4" type="submit">Eliminar</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </section>

  <aside class="rounded-3xl border border-neutral-200 bg-white p-6 h-fit lg:sticky lg:top-24 glass">
    <h2 class="font-semibold">Resumen</h2>
    <div class="mt-4 flex items-center justify-between text-sm">
      <span>Total</span>
      <span class="font-semibold"><%= formatMoney(total) %></span>
    </div>

    <a href="/checkout" class="mt-4 block text-center rounded-2xl bg-neutral-900 text-white px-5 py-3 text-sm hover:opacity-90 transition <%= (!cart || cart.length===0) ? 'pointer-events-none opacity-50' : '' %>">
      Ir a checkout
    </a>

    <p class="mt-3 text-xs text-neutral-500">En prototipo, el pedido se guarda solo en la sesión.</p>
  </aside>
</div>

<%- include('partials/page-end') %>
