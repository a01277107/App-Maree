<%- include('partials/page-start', { title, path }) %>

<a href="/menu" class="text-sm text-neutral-600 hover:text-neutral-900">← Volver al menú</a>

<div class="mt-4 grid lg:grid-cols-2 gap-6">
  <section class="rounded-3xl border border-neutral-200 bg-white p-6 glass">
    <p class="text-xs text-neutral-500"><%= product.category %> / <%= product.group %></p>
    <h1 class="mt-2 text-2xl font-semibold tracking-tight"><%= product.name %></h1>
    <% if (product.desc) { %>
      <p class="mt-2 text-neutral-600"><%= product.desc %></p>
    <% } %>

    <div class="mt-5 flex items-center justify-between">
      <p class="text-lg font-semibold"><%= formatMoney(product.price) %></p>
      <span class="text-xs rounded-full border border-neutral-200 px-3 py-1 text-neutral-600">Disponible</span>
    </div>

    <% if (product.type === 'builder') { %>
      <div class="mt-6 rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
        <p class="text-sm text-neutral-700">Este producto es el flujo de <strong>Arma tu crepa</strong>.</p>
        <a href="/armar-crepa" class="mt-3 inline-flex rounded-2xl bg-neutral-900 text-white px-4 py-2 text-sm hover:opacity-90 transition">Ir al configurador</a>
      </div>
    <% } else { %>
      <form class="mt-6 space-y-4" method="POST" action="/carrito/agregar">
        <input type="hidden" name="id" value="<%= product.id %>" />
        <input type="hidden" name="name" value="<%= product.name %>" />
        <input type="hidden" name="unitPrice" value="<%= product.price %>" />

        <div class="grid grid-cols-2 gap-3">
          <label class="text-sm">
            Cantidad
            <input class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2" type="number" name="qty" min="1" value="1" />
          </label>
          <label class="text-sm">
            Comentario
            <input class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2" type="text" name="note" placeholder="Ej. sin azúcar glass" />
          </label>
        </div>

        <button class="w-full rounded-2xl bg-neutral-900 text-white px-5 py-3 text-sm hover:opacity-90 transition" type="submit">
          Agregar al carrito
        </button>
      </form>
    <% } %>
  </section>

  <aside class="rounded-3xl border border-neutral-200 bg-white p-6 glass">
    <h2 class="font-semibold">Sugerencias</h2>
    <p class="text-sm text-neutral-600 mt-1">En el prototipo estas sugerencias son demo.</p>

    <div class="mt-4 space-y-3">
      <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
        <p class="text-sm font-medium">Agrega nieve</p>
        <p class="text-xs text-neutral-600">+ $25 en crepas/waffles.</p>
      </div>
      <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
        <p class="text-sm font-medium">Extra ingrediente</p>
        <p class="text-xs text-neutral-600">+ $15 si no viene en la receta.</p>
      </div>
    </div>
  </aside>
</div>

<%- include('partials/page-end') %>
