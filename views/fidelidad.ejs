<%- include('partials/page-start', { title, path }) %>

<h1 class="text-2xl md:text-3xl font-semibold tracking-tight">Fidelidad</h1>
<p class="text-neutral-600 text-sm mt-1">Vista demo: puntos, visitas, recompensas y QR (simulado).</p>

<div class="mt-6 grid lg:grid-cols-3 gap-6">
  <section class="rounded-3xl border border-neutral-200 bg-white p-6 glass">
    <p class="text-xs text-neutral-500">Visitas</p>
    <p class="text-3xl font-semibold mt-1"><%= loyalty.visitas %></p>
    <p class="text-xs text-neutral-600 mt-2">Se incrementa con visitas registradas/pedidos (en real).</p>
  </section>

  <section class="rounded-3xl border border-neutral-200 bg-white p-6 glass">
    <p class="text-xs text-neutral-500">Puntos</p>
    <p class="text-3xl font-semibold mt-1"><%= loyalty.puntos %></p>
    <p class="text-xs text-neutral-600 mt-2">Depende de reglas de negocio.</p>
  </section>

  <section class="rounded-3xl border border-neutral-200 bg-white p-6 glass">
    <p class="text-xs text-neutral-500">Nivel</p>
    <p class="text-3xl font-semibold mt-1"><%= loyalty.nivel %></p>
    <div class="mt-4 rounded-2xl border border-neutral-200 bg-neutral-50 p-4 text-sm">
      <p class="font-semibold">QR Wallet (demo)</p>
      <p class="text-neutral-600 text-xs mt-1">En el sistema real se genera y se escanea en caja.</p>
      <div class="mt-3 h-24 rounded-xl bg-white border border-dashed border-neutral-300 grid place-items-center text-xs text-neutral-500 glass">QR</div>
    </div>
  </section>
</div>

<section class="mt-6 rounded-3xl border border-neutral-200 bg-white p-6 glass">
  <h2 class="font-semibold">Recompensas</h2>
  <div class="mt-4 grid md:grid-cols-3 gap-3">
    <% loyalty.recompensas.forEach((r) => { %>
      <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
        <p class="font-medium"><%= r.name %></p>
        <p class="text-xs text-neutral-600 mt-1">Requisito: <%= r.requirement %></p>
        <p class="text-xs mt-2 <%= r.status === 'disponible' ? 'text-green-700' : 'text-neutral-500' %>">
          <%= r.status === 'disponible' ? 'Disponible' : 'Bloqueada' %>
        </p>
      </div>
    <% }) %>
  </div>
</section>

<%- include('partials/page-end') %>
