<%- include('partials/page-start', { title, path }) %>

<a href="/carrito" class="text-sm text-neutral-600 hover:text-neutral-900">← Volver al carrito</a>

<div class="mt-4 grid lg:grid-cols-3 gap-6">
  <section class="lg:col-span-2 rounded-3xl border border-neutral-200 bg-white p-6 glass">
    <h1 class="text-2xl font-semibold tracking-tight">Confirmar pedido</h1>
    <p class="text-sm text-neutral-600 mt-1">En este prototipo, esto simula el cierre del pedido.</p>

    <div class="mt-5 space-y-3">
      <% (cart || []).forEach((item) => { %>
        <div class="flex items-start justify-between gap-4 rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
          <div>
            <p class="font-medium"><%= item.name %></p>
            <p class="text-xs text-neutral-600">x<%= item.qty %></p>
          </div>
          <p class="font-semibold"><%= formatMoney(item.total) %></p>
        </div>
      <% }) %>
    </div>

    <form method="POST" action="/checkout/confirmar" class="mt-6">
      <button class="w-full rounded-2xl bg-neutral-900 text-white px-5 py-3 text-sm hover:opacity-90 transition <%= (!cart || cart.length===0) ? 'pointer-events-none opacity-50' : '' %>" type="submit">
        Confirmar pedido
      </button>
    </form>
  </section>

  <aside class="rounded-3xl border border-neutral-200 bg-white p-6 h-fit glass">
    <h2 class="font-semibold">Total</h2>
    <p class="mt-2 text-3xl font-semibold"><%= formatMoney(total) %></p>
    <p class="mt-2 text-xs text-neutral-500">Pago y validación son demo.</p>
  </aside>
</div>

<%- include('partials/page-end') %>
