<%- include('partials/page-start-admin', { title, path }) %>

<section class="space-y-6">
  <div class="glass p-6">
    <h1 class="text-2xl font-semibold tracking-tight">Dashboard</h1>
    <p class="text-neutral-700 mt-2">Vista general (prototipo). Aquí vive lo esencial para validar el panel administrativo.</p>
  </div>

  <div class="grid md:grid-cols-3 gap-4">
    <div class="glass p-5">
      <div class="text-sm text-neutral-600">Pedidos hoy</div>
      <div class="text-3xl font-semibold mt-1"><%= stats.pedidosHoy %></div>
      <div class="text-sm text-neutral-600 mt-2">Pendientes: <%= stats.pendientes %></div>
    </div>
    <div class="glass p-5">
      <div class="text-sm text-neutral-600">Clientes (mes)</div>
      <div class="text-3xl font-semibold mt-1"><%= stats.clientesMes %></div>
      <div class="text-sm text-neutral-600 mt-2">Mujer/Hombre: <%= stats.genero.mujer %>/<%= stats.genero.hombre %></div>
    </div>
    <div class="glass p-5">
      <div class="text-sm text-neutral-600">Producto top</div>
      <div class="text-xl font-semibold mt-1"><%= stats.topProducto %></div>
      <div class="text-sm text-neutral-600 mt-2">Ingrediente top: <%= stats.topIngrediente %></div>
    </div>
  </div>

  <div class="glass p-6">
    <h2 class="text-lg font-semibold">Accesos rápidos</h2>
    <div class="mt-4 flex flex-wrap gap-3">
      <a class="lovable-btn inline-flex items-center rounded-xl bg-white/70 px-4 py-2 text-sm border border-white/50 hover:bg-white" href="/admin/pedidos">Ver pedidos</a>
      <a class="lovable-btn inline-flex items-center rounded-xl bg-white/70 px-4 py-2 text-sm border border-white/50 hover:bg-white" href="/admin/menu">Gestionar menú</a>
      <a class="lovable-btn inline-flex items-center rounded-xl bg-white/70 px-4 py-2 text-sm border border-white/50 hover:bg-white" href="/admin/promociones">Promociones</a>
      <a class="lovable-btn inline-flex items-center rounded-xl bg-white/70 px-4 py-2 text-sm border border-white/50 hover:bg-white" href="/admin/reportes">Reportes</a>
    </div>
  </div>
</section>


<%- include('partials/page-end-admin') %>
