<%- include('partials/page-start', { title, path }) %>

<section class="grid md:grid-cols-2 gap-8 items-center">
  <div class="space-y-5">
    <p class="inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-white px-3 py-1 text-xs text-neutral-700 glass">
      Cliente: <span class="font-medium"><%= customer?.name || 'Invitado' %></span>
    </p>

    <h1 class="text-3xl md:text-5xl font-semibold tracking-tight">
      Mareé Crepe
      <span class="block text-neutral-500">experiencia, pedidos y fidelidad</span>
    </h1>

    <p class="text-neutral-600 leading-relaxed">
      Prototipo navegable sin React. Explora el menú, arma tu crepa, guarda “Mi crepa” y simula un pedido.
    </p>

    <div class="flex flex-wrap gap-3">
      <a href="/menu" class="rounded-2xl bg-neutral-900 text-white px-5 py-3 text-sm hover:opacity-90 transition">Ver menú</a>
      <a href="/armar-crepa" class="rounded-2xl border border-neutral-300 bg-white px-5 py-3 text-sm hover:bg-neutral-50 transition glass">Arma tu crepa</a>
      <a href="/fidelidad" class="rounded-2xl border border-neutral-300 bg-white px-5 py-3 text-sm hover:bg-neutral-50 transition glass">Fidelidad</a>
    </div>
  </div>

  <div class="relative">
    <div class="card-float rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm glass">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs text-neutral-500">Recomendación</p>
          <p class="font-semibold">Tu pedido más repetido</p>
          <p class="text-neutral-600 text-sm mt-1">(demo) Ferrero Rocher + Iced Latte</p>
        </div>
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-neutral-900 text-white">M</span>
      </div>

      <div class="mt-6 grid grid-cols-3 gap-3">
        <div class="rounded-2xl bg-neutral-50 border border-neutral-200 p-3">
          <p class="text-xs text-neutral-500">Visitas</p>
          <p class="text-lg font-semibold">5</p>
        </div>
        <div class="rounded-2xl bg-neutral-50 border border-neutral-200 p-3">
          <p class="text-xs text-neutral-500">Puntos</p>
          <p class="text-lg font-semibold">120</p>
        </div>
        <div class="rounded-2xl bg-neutral-50 border border-neutral-200 p-3">
          <p class="text-xs text-neutral-500">Nivel</p>
          <p class="text-lg font-semibold">Bronce</p>
        </div>
      </div>

      <div class="mt-6">
        <a class="text-sm text-neutral-900 underline underline-offset-4" href="/perfil">Editar perfil</a>
      </div>
    </div>

    <div class="absolute -z-10 inset-0 blur-3xl opacity-40 bg-gradient-to-tr from-neutral-200 via-white to-neutral-200"></div>
  </div>
</section>

<%- include('partials/page-end') %>
