<%- include('partials/page-start', { title, path }) %>

<h1 class="text-2xl md:text-3xl font-semibold tracking-tight">Perfil</h1>
<p class="text-neutral-600 text-sm mt-1">En prototipo, se guarda en sesión (no BD).</p>

<div class="mt-6 grid lg:grid-cols-2 gap-6">
  <section class="rounded-3xl border border-neutral-200 bg-white p-6 glass">
    <h2 class="font-semibold">Tus datos</h2>

    <form class="mt-4 space-y-4" method="POST" action="/perfil">
      <label class="text-sm block">
        Nombre
        <input class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2" name="name" value="<%= customer?.name || '' %>" placeholder="Ej. Juan Manuel" />
      </label>

      <label class="text-sm block">
        Teléfono
        <input class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2" name="phone" value="<%= customer?.phone || '' %>" placeholder="Ej. 4421234567" />
      </label>

      <button class="rounded-2xl bg-neutral-900 text-white px-5 py-3 text-sm hover:opacity-90 transition" type="submit">Guardar</button>
    </form>
  </section>

  <aside class="rounded-3xl border border-neutral-200 bg-white p-6 glass">
    <h2 class="font-semibold">Notas</h2>
    <ul class="mt-3 text-sm text-neutral-600 list-disc pl-5 space-y-2">
      <li>El login por WhatsApp (OTP) no está implementado aquí, solo simulado.</li>
      <li>En el sistema real, el teléfono es el identificador principal.</li>
    </ul>
  </aside>
</div>

<%- include('partials/page-end') %>
